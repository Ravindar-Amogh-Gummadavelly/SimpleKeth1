# ============================================
# SimpleKeth — Environment Variables
# ============================================

# --- Database ---
DATABASE_URL=postgresql://simpleketh:simpleketh_pass@localhost:5432/simpleketh
POSTGRES_USER=simpleketh
POSTGRES_PASSWORD=simpleketh_pass
POSTGRES_DB=simpleketh

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
API_BEARER_TOKEN=sk-simpleketh-dev-token-2026

# --- Weather API (OpenWeatherMap) ---
OPENWEATHER_API_KEY=your_weather_api_key_here

# --- Twilio (SMS/Voice) — Add your keys later ---
TWILIO_ACCOUNT_SID=mock_sid
TWILIO_AUTH_TOKEN=mock_token
TWILIO_PHONE_NUMBER=+1234567890

# --- Firebase (Push Notifications) — Add your keys later ---
FIREBASE_PROJECT_ID=simpleketh-dev
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# --- Service URLs ---
PREDICTION_SERVICE_URL=http://localhost:8001
RECOMMENDATION_SERVICE_URL=http://localhost:8002
NOTIFICATION_SERVICE_URL=http://localhost:8003
PROFILE_SERVICE_URL=http://localhost:8004

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_APP_NAME=SimpleKeth
